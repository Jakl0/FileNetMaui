<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zad1filenetmaui.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Entry Placeholder="Tekst do zapisania" x:Name="TekstEntry"/>
            <Button Text="Zapisz do pliku" Clicked="OnSaveClick"/>

            <Button Text="Odczytaj z pliku" Clicked="OnReadClick"/>

            <Label x:Name="DisplayLabel"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

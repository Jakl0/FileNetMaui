<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zad4filenetmaui.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Editor HeightRequest="150"  x:Name="expEditor"/>

            <Button x:Name="expButton" Clicked="OnExport" Text="Eksportuj"/>
            <Button x:Name="impButton" Clicked="OnImport" Text="Importuj"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
